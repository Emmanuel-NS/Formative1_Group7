# PostgreSQL (Supabase / Aiven / Neon / local)
POSTGRES_HOST=your-project.supabase.co
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=postgres

# MongoDB Atlas
